generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  schedules Schedule[]
  projects  Project[]
}

model User {
  id        String   @id @default(uuid())
  email     String  @unique
  password  String
  name      String
  role      UserRole @default(EMPLOYEE)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company?   @relation(fields: [companyId], references: [id])
  clockings Clocking[]
  vacations Vacation[]

  @@index([companyId])
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

model Clocking {
  id         String      @id @default(uuid())
  userId     String
  type       ClockingType
  timestamp  DateTime    @default(now())
  latitude   Float?
  longitude  Float?
  deviceInfo String?
  notes     String?
  projectId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([projectId])
}

enum ClockingType {
  ENTRY
  EXIT
}

model Schedule {
  id          String       @id @default(uuid())
  companyId    String
  name        String
  type        ScheduleType
  startTime   String
  endTime    String
  flexStart  String?
  flexEnd   String?
  workingDays Int[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

enum ScheduleType {
  FLEXIBLE
  SEMIFLEXIBLE
  STRICT
}

model Project {
  id          String   @id @default(uuid())
  companyId   String
  name       String
  description String?
  color      String   @default("#3B82F6")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  clockings Clocking[]

  @@index([companyId])
}

model Vacation {
  id          String       @id @default(uuid())
  userId      String
  type        VacationType
  startDate   DateTime
  endDate     DateTime
  status      VacationStatus @default(PENDING)
  reason      String?
  approvedBy  String?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([startDate])
}

enum VacationType {
  VACATION
  SICK_LEAVE
  PERSONAL
  OTHER
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}